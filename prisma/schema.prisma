generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id          String     @id @default(uuid())
  title       String
  department  String
  term        String
  materials   Material[]
  createdAt   DateTime   @default(now())
}

model Material {
  id          String   @id @default(uuid())
  title       String
  type        String   // Lecture Notes, Assignment, Syllabus, Other
  description String?
  url         String
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}